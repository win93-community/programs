{
  name: "WebVoxel",
  command: "webvox",
  categories: ["Editor","3d","Voxel"],
  about: "./about.md",
  

  width: 641,
  height: 481,

  maximizable: true,
  resizable: false,

decode: {
    types: [
      {
        description: "Voxel file",
        accept: {
          "application/x-vox": [".vox"],
        },
        icons: [
          { src: "./icons/32x32/subtype/x-vox.png", sizes: "32x32" },
        ],
      }
    ],
  },

  document: "./index.html",
}
