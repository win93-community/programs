{
  name: "TextEdit",
  command: "text",
  categories: ["Utility", "TextEditor"],
  description: "Simple text editor using textarea",

  width: 380,
  height: 260,
  maximized: "{{pointer.isTouch}}",

  decode: {
    types: [
      {
        description: "Text document",
        accept: [
          "text/*", //
          "application/json",
          "application/json5",
          "application/rss+xml",
          "application/xml",
        ],
      },
      {
        description: "FIGlet font",
        accept: {
          // TODO: add a way to register an ext without filling on normalize
          "text/plain": [".flf"],
        },
        // icons: [
        //   // { src: "/42/assets/icons/32x32/type/font.png", sizes: "32x32" }, //
        //   { src: "../../../../42/assets/icons/32x32/type/font.png", sizes: "32x32" }, //
        // ],
      },
    ],
  },

  module: "./TextEdit.js",
}
