{
  name: "CodeMirror",
  command: "code",
  categories: ["Utility", "TextEditor"],
  // description: "Code editor powered by [CodeMirror](https://codemirror.net/).",

  width: 470,
  height: 340,
  animation: false,
  maximized: "{{pointer.isTouch}}",

  decode: {
    types: [
      {
        description: "Source Code",
        accept: [
          "text/*", //
          "application/json",
          "application/json5",
          "application/rss+xml",
          "application/xml",
        ],
      },
    ],
  },

  about: "./about.md",
  module: "./CodeMirror.js",
}
