{
  name: "ImageViewer",
  command: "image",
  categories: ["Graphics", "Viewer"],

  inset: true,
  dialog: {
    skipSave: ["width", "height"],
    style: { minHeight: 100 },
  },

  decode: {
    startIn: "pictures",
    types: [
      { description: "Image", accept: "image/*" }, //
    ],
  },

  module: "./ImageViewer.js",
}
