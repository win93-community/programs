{
  name: "ShaderPlayer",
  command: "shader",
  categories: ["Graphics", "Viewer"],

  width: 256,
  height: 256,
  inset: true,

  decode: {
    startIn: "documents/shaders",
    types: [
      {
        description: "Shader Source",
        accept: {
          "text/x-glsl": [".glsl"],
        },
        icons: [
          { src: "./icons/16x16/subtype/x-glsl.png", sizes: "16x16" },
          { src: "./icons/32x32/subtype/x-glsl.png", sizes: "32x32" },
        ],
      },
    ],
  },

  module: "./ShaderPlayer.js",
}
