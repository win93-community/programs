{
  name: "Scratch Player",
  command: "scratch",
  categories: ["player"],

  width: 480,
  height: 384,
  maximizable: false,
  resizable: false,
  minimizable: false,

  decode: {
    startIn: "roms/scratch",
    types: [
      {
        description: "Scratch project",
        accept: {
          "application/zip": [".sb3", ".sb2", ".sb"],
        },
        icons: [{ src: "./icons/32x32/ext/sb3.png", sizes: "32x32" }],
      },
    ],
  },

  about: "./about.md",
  document: "./index.html",
}
