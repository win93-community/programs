{
  name: "Flash Player",
  command: "flash",
  categories: ["System", "Emulator", "Flash"],
  description: "Flash player based on ruffle.js",

  width: 400,
  height: 300,
  inset: true,

  dialog: {
    class: {
      "dialog-fullscreen--body": true,
    },
  },

  decode: {
    startIn: "roms/flash",
    types: [
      {
        description: "Shockwave Flash file",
        accept: {
          "application/x-shockwave-flash": [".swf"],
        },
        icons: [
          {
            src: "./icons/16x16/subtype/x-shockwave-flash.png",
            sizes: "16x16",
          },
          {
            src: "./icons/32x32/subtype/x-shockwave-flash.png",
            sizes: "32x32",
          },
        ],
      },
    ],
  },

  module: "./FlashPlayer.js",
  document: "./index.html",
}
