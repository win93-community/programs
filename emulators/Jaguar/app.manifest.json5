{
  name: "Jaguar",
  command: "jaguar",
  description: "https://github.com/EmulatorJS/virtualjaguar-libretro",
  categories: ["Emulator"],
  // suspendIntensiveTasks: true,

  width: 256,
  height: 224,
  inset: true,
  maximized: "{{pointer.isTouch}}",
  resizable: false,

  decode: {
    types: [
      {
        description: "Atari Jaguar ROM",
        accept: {
          "application/x-jaguar-rom": [".j64"],
        },
        icons: [{ src: "./icons/32x32/subtype/x-jaguar-rom.png", sizes: "32x32" }],
      },
      {
        description: "Compressed Jaguar ROM",
        accept: { "application/zip": [], "application/x-7z-compressed": [] },
      },
    ],
  },

  document: "./index.html",
}
