{
  name: "prBoom",
  command: "prboom",
  description: "https://github.com/EmulatorJS/libretro-prboom",
  categories: ["Emulator"],
  // suspendIntensiveTasks: true,

  width: 320,
  height: 200,
  inset: true,
  maximized: "{{pointer.isTouch}}",
  resizable: false,

  decode: {
    types: [
      {
        description: "Wad ROM",
        accept: {
          "application/x-wad-rom": [".wad"],
        },
        icons: [{ src: "./icons/32x32/subtype/x-wad-rom.png", sizes: "32x32" }],
      },
      {
        description: "Compressed Wad ROM",
        accept: { "application/zip": [], "application/x-7z-compressed": [] },
      },
    ],
  },

  document: "./index.html",
}
