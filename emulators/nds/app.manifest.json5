{
  name: "nds",
  command: "nds",
  description: "https://github.com/EmulatorJS/melonDS",
  categories: ["Emulator"],
  suspendIntensiveTasks: true,

  options: {
    rewindEnabled: false,
    audioLatency: 256,
  },

  width: 256,
  height: 384,
  inset: true,
  maximized: "{{pointer.isTouch}}",
  resizable: false,

  decode: {
    types: [
      {
        description: "Nintendo DS ROM",
        accept: {
          "application/x-nintendo-ds-rom": [".nds"],
        },
        icons: [{ src: "./icons/32x32/subtype/x-nintendo-ds-rom.png", sizes: "32x32" }],
      },
      {
        description: "Compressed NDS ROM",
        accept: { "application/zip": [], "application/x-7z-compressed": [] },
      },
    ],
  },

  document: "./index.html",
}
