{
  name: "a5200",
  command: "a5200",
  description: "https://github.com/EmulatorJS/",
  categories: ["Emulator"],
  // suspendIntensiveTasks: true,

  width: 332,
  height: 258,
  inset: true,
  maximized: "{{pointer.isTouch}}",
  resizable: false,

  decode: {
    types: [
      {
        description: "Atari 5200 ROM",
        accept: {
          "application/x-atari5200-rom": [".a52"],
        },
        icons: [{ src: "./icons/32x32/subtype/x-atari5200-rom.png", sizes: "32x32" }],
      },
      {
        description: "Compressed Atari 5200 ROM",
        accept: { "application/zip": [], "application/x-7z-compressed": [] },
      },
    ],
  },

  document: "./index.html",
}
