{
  name: "sms",
  command: "sms",
  description: "https://github.com/EmulatorJS/Genesis-Plus-GX",
  categories: ["Emulator"],
  // suspendIntensiveTasks: true,

  width: 256,
  height: 192,
  inset: true,
  maximized: "{{pointer.isTouch}}",
  resizable: false,

  decode: {
    types: [
      {
        description: "Sega Master System ROM",
        accept: {
          "application/x-sms-rom": [".sms"],
        },
        icons: [{ src: "./icons/32x32/subtype/x-sms-rom.png", sizes: "32x32" }],
      },
      {
        description: "Compressed SMS ROM",
        accept: { "application/zip": [], "application/x-7z-compressed": [] },
      },
    ],
  },

  document: "./index.html",
}
