{
  name: "n64",
  command: "n64",
  description: "https://github.com/EmulatorJS/parallel-n64",
  // description: "https://github.com/EmulatorJS/mupen64plus-libretro-nx",
  // description: "https://github.com/nbarkhina/N64Wasm",
  categories: ["Emulator"],
  suspendIntensiveTasks: true,

  options: {
    rewindEnabled: false,
  },

  width: 320,
  height: 240,
  inset: true,
  maximized: "{{pointer.isTouch}}",
  resizable: false,

  decode: {
    types: [
      {
        description: "Nintendo 64 ROM",
        accept: {
          "application/x-n64-rom": [".n64", ".v64", ".z64"],
        },
        icons: [{ src: "./icons/32x32/subtype/x-n64-rom.png", sizes: "32x32" }],
      },
      {
        description: "Compressed N64 ROM",
        accept: { "application/zip": [], "application/x-7z-compressed": [] },
      },
    ],
  },

  document: "./index.html",
}
