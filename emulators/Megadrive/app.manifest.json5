{
  name: "Megadrive",
  command: "smd",
  description: "https://github.com/EmulatorJS/Genesis-Plus-GX",
  categories: ["Emulator"],
  suspendIntensiveTasks: true,

  width: 320,
  height: 224,
  inset: true,
  maximized: "{{pointer.isTouch}}",
  resizable: false,

  decode: {
    types: [
      {
        description: "Sega Mega Drive ROM",
        accept: {
          "application/x-genesis-rom": [".smd", ".md", ".gen"],
        },
        icons: [{ src: "./icons/32x32/subtype/x-genesis-rom.png", sizes: "32x32" }],
      },
      {
        description: "Compressed Mega Drive ROM",
        accept: { "application/zip": [], "application/x-7z-compressed": [] },
      },
    ],
  },

  document: "./index.html",
}
