{
  name: "psx",
  command: "psx",
  description: "https://github.com/EmulatorJS/pcsx_rearmed",
  categories: ["Emulator"],
  suspendIntensiveTasks: true,

  width: 320,
  height: 240,
  inset: true,
  maximized: "{{pointer.isTouch}}",
  resizable: false,

  options: {
    audioLatency: 128,
    aspectRatio: 1.333,
  },

  decode: {
    // [".mdf", ".pbp", ".toc", ".cbn", ".m3u", ".ccd"]
    types: [
      {
        description: "MAME compressed hard disk image",
        accept: { "application/x-mame-chd": [".chd"] },
      },
      {
        description: "Raw disk image",
        accept: { "application/vnd.efi.img": [".img"] },
      },
      {
        description: "CD image cuesheet",
        accept: { "application/x-cue": [".cue"] },
      },
      {
        description: "Binary Data",
        accept: { "application/octet-stream": [".bin"] },
      },
      {
        description: "Compressed PSX ROM",
        accept: { "application/zip": [], "application/x-7z-compressed": [] },
      },
    ],
  },

  document: "./index.html",
}
