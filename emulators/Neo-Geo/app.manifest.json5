{
  name: "Neo-Geo",
  command: "neogeo",
  description: "https://github.com/EmulatorJS/FBNeo",
  categories: ["Emulator"],
  suspendIntensiveTasks: true,

  width: 320,
  height: 224,
  inset: true,
  maximized: "{{pointer.isTouch}}",
  resizable: false,

  options: {
    core: "fbneo",
    // core: "mame2003",
    // core: "mame2003_plus",
    // bios: "fbneo",
    // core: "fbalpha2012_cps1",
    // core: "fbalpha2012_cps2",
  },

  decode: {
    types: [
      {
        description: "Compressed Neo-Geo ROM",
        accept: { "application/zip": [], "application/x-7z-compressed": [] },
      },
    ],
  },

  document: "./index.html",
}
