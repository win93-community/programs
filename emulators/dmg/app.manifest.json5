{
  name: "dmg",
  command: "dmg",
  description: "https://github.com/EmulatorJS/gambatte-libretro",
  categories: ["Emulator"],
  // suspendIntensiveTasks: true,

  width: 160,
  height: 144,
  inset: true,
  maximized: "{{pointer.isTouch}}",

  decode: {
    startIn: "roms/dmg",
    types: [
      {
        description: "Game Boy ROM",
        accept: {
          "application/x-gameboy-rom": [".gb", ".dmg"],
        },
        icons: [
          { src: "./icons/16x16/subtype/x-gameboy-rom.png", sizes: "16x16" },
          { src: "./icons/32x32/subtype/x-gameboy-rom.png", sizes: "32x32" },
        ],
      },
      {
        description: "Game Boy Color ROM",
        accept: {
          "application/x-gameboy-color-rom": [".gbc"],
        },
        icons: [
          { src: "./icons/16x16/subtype/x-gameboy-color-rom.png", sizes: "16x16" },
          { src: "./icons/32x32/subtype/x-gameboy-color-rom.png", sizes: "32x32" },
        ],
      },
      {
        description: "Compressed Game Boy ROM",
        accept: { "application/zip": [], "application/x-7z-compressed": [] },
      },
    ],
  },

  document: "./index.html",
}
