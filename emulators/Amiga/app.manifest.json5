{
  name: "Amiga",
  command: "a500",
  description: "https://github.com/EmulatorJS/libretro-uae",
  categories: ["Emulator"],
  // suspendIntensiveTasks: true,

  width: 720,
  height: 576,
  inset: true,
  maximized: "{{pointer.isTouch}}",
  resizable: true,

  decode: {
    types: [
      {
        description: "Amiga 500 ROM",
        accept: {
          "application/x-a500-rom": [".adf"],
        },
        icons: [{ src: "./icons/32x32/subtype/x-a500-rom.png", sizes: "32x32" }],
      },
      {
        description: "Compressed Amiga 500 ROM",
        accept: { "application/zip": [], "application/x-7z-compressed": [] },
      },
    ],
  },

  document: "./index.html",
}
