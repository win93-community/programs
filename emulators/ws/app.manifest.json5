{
  name: "ws",
  command: "ws",
  description: "https://github.com/EmulatorJS/beetle-wswan-libretro",
  categories: ["Emulator"],
  // suspendIntensiveTasks: true,

  width: 224,
  height: 144,
  inset: true,
  maximized: "{{pointer.isTouch}}",
  resizable: false,

  decode: {
    types: [
      {
        description: "WonderSwan ROM",
        accept: {
          "application/x-ws-rom": [".ws"],
        },
        icons: [{ src: "./icons/32x32/subtype/x-ws-rom.png", sizes: "32x32" }],
      },
      {
        description: "WonderSwan Color ROM",
        accept: {
          "application/x-wsc-rom": [".wsc"],
        },
        icons: [{ src: "./icons/32x32/subtype/x-wsc-rom.png", sizes: "32x32" }],
      },
      {
        description: "Compressed WonderSwan ROM",
        accept: { "application/zip": [], "application/x-7z-compressed": [] },
      },
    ],
  },

  document: "./index.html",
}
