{
  name: "snes",
  command: "snes",
  description: "https://github.com/EmulatorJS/snes9x",
  categories: ["Emulator"],
  suspendIntensiveTasks: true,

  width: 256,
  height: 224,
  inset: true,
  maximized: "{{pointer.isTouch}}",
  resizable: false,

  decode: {
    types: [
      {
        description: "Nintendo Super NES ROM",
        accept: {
          "application/vnd.nintendo.snes.rom": [".smc", ".sfc", ".swc", ".fig", ".bs", ".st"],
        },
        icons: [{ src: "./icons/32x32/subtype/vnd.nintendo.snes.rom.png", sizes: "32x32" }],
      },
      {
        description: "Compressed SNES ROM",
        accept: { "application/zip": [], "application/x-7z-compressed": [] },
      },
    ],
  },

  document: "./index.html",
}
