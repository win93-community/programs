{
  name: "Lynx",
  command: "lynx",
  description: "https://github.com/EmulatorJS/",
  categories: ["Emulator"],
  // suspendIntensiveTasks: true,

  width: 256,
  height: 224,
  inset: true,
  maximized: "{{pointer.isTouch}}",
  resizable: false,

  decode: {
    types: [
      {
        description: "Atari Lynx ROM",
        accept: {
          "application/x-lynx-rom": [".lnx"],
        },
        icons: [{ src: "./icons/32x32/subtype/x-lynx-rom.png", sizes: "32x32" }],
      },
      {
        description: "Compressed Lynx ROM",
        accept: { "application/zip": [], "application/x-7z-compressed": [] },
      },
    ],
  },

  document: "./index.html",
}
