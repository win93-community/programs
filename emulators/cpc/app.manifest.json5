{
  name: "cpc",
  command: "cpc",
  description: "https://github.com/EmulatorJS/libretro-crocods",
  categories: ["Emulator"],
  // suspendIntensiveTasks: true,

  width: 320,
  height: 200,
  inset: true,
  maximized: "{{pointer.isTouch}}",
  resizable: false,

  decode: {
    types: [
      {
        description: "CPC ROM",
        accept: {
          "application/x-cpc-rom": [".dsk"],
        },
        icons: [{ src: "./icons/32x32/subtype/x-cpc-rom.png", sizes: "32x32" }],
      },
      {
        description: "Compressed CPC ROM",
        accept: { "application/zip": [], "application/x-7z-compressed": [] },
      },
    ],
  },

  document: "./index.html",
}
