{
  name: "vb",
  command: "virtualboy",
  description: "https://github.com/EmulatorJS/",
  categories: ["Emulator"],
  // suspendIntensiveTasks: true,

  width: 256,
  height: 224,
  inset: true,
  maximized: "{{pointer.isTouch}}",
  resizable: false,

  decode: {
    types: [
      {
        description: "Nintendo Virtual Boy ROM",
        accept: {
          "application/x-vb-rom": [".vb"],
        },
        icons: [{ src: "./icons/32x32/subtype/x-vb-rom.png", sizes: "32x32" }],
      },
      {
        description: "Compressed NVB ROM",
        accept: { "application/zip": [], "application/x-7z-compressed": [] },
      },
    ],
  },

  document: "./index.html",
}
