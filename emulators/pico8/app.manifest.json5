{
  name: "pico8",
  command: "pico8",
  description: "https://pico-8.com",
  categories: ["Emulator"],
  // suspendIntensiveTasks: true,

  zoom: 2,
  width: 128,
  height: 128,
  inset: true,
  maximized: "{{pointer.isTouch}}",

  decode: {
    types: [
      {
        description: "pico8 ROM",
        accept: {
          "image/png": [".p8.png"],
        },
        icons: [
          { src: "./icons/16x16/ext/p8.png.png", sizes: "16x16" },
          { src: "./icons/32x32/ext/p8.png.png", sizes: "32x32" },
        ],
      },
      // {
      //   description: "PICO-8 Source",
      //   accept: {
      //     "text/plain": [".p8"],
      //   },
      //   icons: [
      //     { src: "./icons/16x16/ext/p8.png", sizes: "16x16" },
      //     { src: "./icons/32x32/ext/p8.png", sizes: "32x32" },
      //   ],
      // },
    ],
  },

  document: "./index.html",
}
