{
  name: "Dosbox",
  command: "dosbox",
  description: "Based on [js-dos](https://js-dos.com/).",
  categories: ["Emulator"],

  width: 640,
  height: 480,
  inset: true,

  decode: {
    startIn: "roms/dosbox",
    types: [
      {
        description: "JS-DOS ROM",
        accept: { "application/x-jsdos-rom": [".jsdos"] },
        icons: [{ src: "./icons/32x32/subtype/x-jsdos-rom.png", sizes: "32x32" }],
      },
    ],
  },

  document: "./index.html",
}
