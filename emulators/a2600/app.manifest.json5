{
  name: "a2600",
  command: "a2600",
  description: "https://github.com/EmulatorJS/",
  categories: ["Emulator"],
  // suspendIntensiveTasks: true,

  width: 256,
  height: 224,
  inset: true,
  maximized: "{{pointer.isTouch}}",
  resizable: false,

  decode: {
    types: [
      {
        description: "Atari 2600 ROM",
        accept: {
          "application/x-atari2600-rom": [".a26"],
        },
        icons: [{ src: "./icons/32x32/subtype/x-atari2600-rom.png", sizes: "32x32" }],
      },
      {
        description: "Compressed Atari 2600 ROM",
        accept: { "application/zip": [], "application/x-7z-compressed": [] },
      },
    ],
  },

  document: "./index.html",
}
